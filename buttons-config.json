        "ابدأ رحلتك"
      ]
    },
    "accent": {
      "classes": ["btn-accent", "btn--accent", "button-accent"],
      "usage": "الأزرار الثانوية (روابط بديلة أو مساعدة)",
      "colors": {
        "background": "#25bdb7",
        "hover": "#0f828a",
        "text": "#ffffff"
      },
      "examples": [
        "اعرف المزيد",
        "تواصل معنا",
        "احجز موعد"
      ]
    },
    "outline": {
      "classes": ["btn-outline", "btn--outline", "button-outline"],
      "usage": "الأزرار البيضاء ذات حدود (مثلاً View courses)",
      "colors": {
        "background": "transparent",
        "border": "#0f828a",
        "text": "#0f828a",
        "hoverBackground": "#0f828a",
        "hoverText": "#ffffff"
      },
      "examples": [
        "View Courses",
        "عرض البرامج",
        "تصفح الدورات"
      ]
    },
    "soft": {
      "classes": ["btn-soft", "btn--soft", "button-soft"],
