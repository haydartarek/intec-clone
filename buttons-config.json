  "files": {
    "css": "/assets/css/main.css",
    "test": "/test-buttons.html",
    "guide": "/BUTTONS_GUIDE.md",
    "cheatsheet": "/BUTTONS_CHEATSHEET.txt",
    "status": "/BUTTONS_IMPLEMENTATION_STATUS.md",
