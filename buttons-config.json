  "bestPractices": {
    "do": [
      "استخدم btn-primary للإجراءات الحاسمة",
      "استخدم btn-soft في الكروت",
      "احترم التسلسل الهرمي البصري",
      "استخدم الأحجام المناسبة للسياق",
      "اختبر على جميع الأجهزة"
    ],
    "dont": [
      "لا تستخدم أكثر من btn-primary واحد في نفس القسم",
      "لا تخلط بين الأنماط القديمة والجديدة",
      "لا تستخدم ألوان خارج النظام",
      "لا تنسى حالة hover",
      "لا تهمل الـ accessibility"
    ]
  },
  "migration": {
    "oldClasses": {
      "button": "btn-primary",
      "button button--ghost": "btn-outline",
      "button button--secondary": "btn-accent"
