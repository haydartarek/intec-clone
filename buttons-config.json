      "colors": {
        "background": "#e0f7f6",
        "border": "rgba(15, 130, 138, 0.1)",
        "text": "#0f828a",
        "hoverBackground": "#25bdb7",
        "hoverText": "#ffffff"
      },
      "examples": [
        "Plan Intake",
        "خطط دراستك",
        "احجز استشارة"
      ]
    }
  },
  "sizes": {
    "small": {
      "class": "btn-sm",
      "padding": "var(--space-2) var(--space-4)",
      "fontSize": "var(--text-sm)"
    },
    "normal": {
      "class": "",
      "padding": "var(--space-3) var(--space-6)",
      "fontSize": "var(--text-body)"
    },
    "large": {
      "class": "btn-lg",
      "padding": "var(--space-4) var(--space-8)",
      "fontSize": "var(--text-lg)"
    }
  },
  "states": {
    "normal": "default state",
    "hover": "transform: translateY(-2px) + shadow-md",
    "active": "transform: translateY(0) + shadow-sm",
    "disabled": "opacity: 0.5, cursor: not-allowed"
  },
  "useCases": {
    "heroSection": {
      "primary": "btn-primary btn-lg",
      "secondary": "btn-outline btn-lg"
    },
    "courseCard": {
      "primary": "btn-soft",
      "secondary": "btn-outline btn-sm"
    },
    "ctaSection": {
      "primary": "btn-primary btn-lg"
    },
    "forms": {
      "submit": "btn-primary",
      "save": "btn-accent"
    }
  },
  "colorPalette": {
    "primary": "#0f828a",
    "primaryDark": "#0b5c61",
    "accent": "#25bdb7",
    "accentSoft": "#e0f7f6",
    "white": "#ffffff"
  },
  "features": [
    "4 أنواع أزرار متكاملة",
    "3 أحجام (small, normal, large)",
    "4 حالات (normal, hover, active, disabled)",
    "دعم كامل لـ RTL و LTR",
    "تأثيرات انتقالية سلسة",
    "ظلال متدرجة احترافية",
    "توافق كامل مع المتصفحات",
    "Responsive بالكامل",
    "Accessible (WCAG compliant)"
