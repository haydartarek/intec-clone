      "home.partners.label": "Partners",
      "home.partners.title": "Collaboration with companies, authorities and non-profits",
      "home.partners.lead":
        "More than twenty years of experience resulted in a strong network of employers and social partners that invest in digital skills and inclusive teams.",
      "home.partnerCallout.title": "INOPTEC+: your reliable IT support partner",
      "home.partnerCallout.body":
        "Our in-house IT support cell provides helpdesk services, microlearning and onsite interventions for organisations that want to strengthen their digital transformation. Request an introduction meeting.",
      "home.partnerCallout.cta": "Contact us",

      "support.hero.eyebrow": "Programme",
      "support.hero.title": "PC & Network Technician",
      "support.hero.lead":
        "Build your future in ICT support with a hands-on track that blends hardware, networking and customer-facing skills. Learn to analyse incidents, secure systems and guide users professionally.",
      "support.hero.ctaPrimary": "Book your intake",
      "support.hero.ctaSecondary": "View programme",
      "support.hero.caption":
        "Learn in small groups with modern labs and coaching from industry experts.",
      "support.hero.metaTitle": "Upcoming start dates",
      "support.hero.metaDates": "9 March 2026 (registrations open)",
      "support.hero.metaNote":
        "Register up to six months before the start. Info sessions and assessments help determine if this path fits you.",
      "support.overview.label": "What you learn",
      "support.overview.title": "A solid base in IT support",
      "support.overview.text1":
        "You become the first point of contact for workstations, servers and users. Combine troubleshooting with proactive monitoring and documentation following ITIL standards.",
      "support.overview.text2":
        "Beyond technology we focus on communication, service skills and workplace organisation, enabling you to report clearly, prioritise tasks and support teams in hybrid environments.",
      "support.overview.listTitle": "During the programme",
      "support.overview.list1": "70% practical labs covering hardware, networking and security",
      "support.overview.list2": "Internship with a partner company or social-profit organisation",
      "support.overview.list3": "Coaching by digicoaches plus language support",
      "support.overview.list4": "Soft skills: customer communication, teamwork and planning",
      "support.modules.label": "Curriculum",
      "support.modules.title": "Modules & subject areas",
      "support.modules.lead":
        "A mix of fundamentals and specialisations prepares you for helpdesk, onsite support or technical operations within SMEs, public sector and integrators.",
      "support.modules.deviceTitle": "Workplace & hardware",
      "support.modules.deviceBody":
        "Assembly, imaging, maintenance and troubleshooting of PCs, laptops and peripherals. Work with diagnostic tools and lifecycle best practices.",
      "support.modules.networkTitle": "Networking & cloud",
      "support.modules.networkBody":
        "LAN/WAN basics, Wi-Fi, routing & switching, introduction to Azure and M365 administration. Configure, monitor and resolve incidents.",
      "support.modules.osTitle": "Operating systems",
      "support.modules.osBody":
        "Windows 11, Windows Server and Linux basics. Automation with PowerShell, access management and secure configurations.",
      "support.modules.securityTitle": "Security & service",
      "support.modules.securityBody":
        "Endpoint protection, backup, disaster recovery and documentation. Work with ITIL processes, SLAs and service desk tooling.",
      "support.journey.label": "Journey",
      "support.journey.title": "From intake to your first job",
      "support.journey.step1Title": "Intake & fundamentals",
      "support.journey.step1Body":
        "Info session, assessments and language check. You start with workplace fundamentals, safety and service desk flow.",
      "support.journey.step2Title": "Deep dive labs",
      "support.journey.step2Body":
        "Project-based labs on networking, virtualisation and scripting. Coaching on troubleshooting and customer communication.",
      "support.journey.step3Title": "Internship & certification",
      "support.journey.step3Body":
        "6 to 8 week internship. Prepare for certificates such as CompTIA ITF+ or Microsoft Fundamentals.",
      "support.journey.step4Title": "Career coaching",
      "support.journey.step4Body":
        "CV and interview coaching, partner matching and follow-up during your first year on the job.",
      "program.info.label": "Practical",
      "program.info.generalTitle": "General information about this programme",
      "program.info.item1": "Tuition: Free",
      "program.info.item2": "Language: Dutch",
      "program.info.item3": "Prerequisites: None required",
      "program.info.item4": "Programme duration: 1 year",
      "program.info.item5": "Classes: Monday to Friday, 08:30 - 17:00 (start at 09:00)",
      "program.info.note":
        "Do you have specific needs to participate in the selection or programme? For example because of a physical limitation. Let us know.",
      "program.info.locationTitle": "Location",
      "program.info.locationBody":
        "Campus Rouppeplein 16, 1000 Brussels. This venue is easily accessible by public transport.",
      "program.info.benefitsTitle": "Benefits",
      "program.info.benefit1": "Travel costs are reimbursed during the programme.",
      "program.info.benefit2": "Childcare or after-school care costs are reimbursed.",
      "program.info.benefit3":
        "You remain legally covered for unemployment benefits and other allowances throughout the programme.",
      "support.cta.title": "Ready to launch as a PC & Network Technician?",
      "support.cta.body":
        "Book your intake and discover how we personalise your learning path. Our coaches are ready to answer your questions.",
      "support.cta.primary": "Book intake",
      "support.cta.secondary": "Ask a question",
      "program.cta.eyebrow": "Next step",

      "python.hero.eyebrow": "Programme",
      "python.hero.title": "Network Administrator with Python",
      "python.hero.lead":
        "Learn to design and operate enterprise networks while automating workflows with Python. This track combines infrastructure, cloud and scripting to prepare you for modern network environments.",
      "python.hero.ctaPrimary": "Book your intake",
      "python.hero.ctaSecondary": "View programme",
      "python.hero.caption":
        "Bring together networking labs with Python automation and DevOps tooling.",
      "python.hero.metaTitle": "Start date",
      "python.hero.metaDates": "18 November 2025",
      "python.hero.metaNote":
        "Register up to six months before the start. After the intake you follow a preparatory sprint with Python essentials.",
      "python.overview.label": "What you learn",
      "python.overview.title": "Automating networks end-to-end",
      "python.overview.text1":
        "Deep dive into routing, switching, firewalls and wireless. Use Python to build scripts that manage configurations, automate monitoring and call APIs.",
      "python.overview.text2":
        "We link infrastructure operations with DevOps practices: version control, CI/CD for network code and thorough documentation to deliver changes safely.",
      "python.overview.listTitle": "During the programme",
      "python.overview.list1": "Network design labs with Cisco and open source environments",
      "python.overview.list2": "Python sprints covering automation, REST APIs and data parsing",
      "python.overview.list3": "Introductions to cloud networking (Azure, AWS) and containerisation",
      "python.overview.list4": "Internship project focused on network operations or NetDevOps",
      "python.modules.label": "Curriculum",
      "python.modules.title": "Modules & specialisations",
      "python.modules.lead":
        "Combine networking fundamentals with automation and security. Each module ends with a lab case to validate your skills.",
      "python.modules.networkTitle": "Enterprise networking",
      "python.modules.networkBody":
        "Routing & switching, VLANs, QoS and wireless design. Implementation using Cisco and open standards.",
      "python.modules.pythonTitle": "Python & automation",
      "python.modules.pythonBody":
        "Python fundamentals, object-oriented programming, APIs, Ansible and scripting for configuration management.",
      "python.modules.cloudTitle": "Cloud & observability",
      "python.modules.cloudBody":
        "Networking in Azure and AWS, IaC with Terraform, log analysis and monitoring with Grafana and Prometheus.",
      "python.modules.securityTitle": "Security & automation ops",
      "python.modules.securityBody":
        "Zero trust, firewall policies, automated compliance checks and incident response workflows.",
      "python.journey.label": "Journey",
      "python.journey.title": "Your learning path",
      "python.journey.step1Title": "Intake & fundamentals",
      "python.journey.step1Body":
        "Network and language screening plus onboarding into Python fundamentals and core concepts.",
      "python.journey.step2Title": "Network expertise",
      "python.journey.step2Body":
        "Configuration and troubleshooting in physical and virtual labs including Cisco Packet Tracer and GNS3.",
      "python.journey.step3Title": "Automation",
      "python.journey.step3Body":
        "Python and Ansible projects, DevOps workflows and integration with monitoring platforms.",
      "python.journey.step4Title": "Internship & certification",
      "python.journey.step4Body":
        "Eight week internship, preparation for Cisco CCNA, DevNet Associate or PCEP certifications and intensive career coaching.",
      "python.cta.title": "Shape the future with networking & Python",
      "python.cta.body":
        "Book your intake and discover how this track prepares you for roles such as network engineer, NetDevOps or cloud operations specialist.",
      "python.cta.primary": "Book intake",
      "python.cta.secondary": "Ask a question",

      "system.hero.eyebrow": "Programme",
      "system.hero.title": "System Administrator",
      "system.hero.lead":
        "Manage hybrid infrastructures with confidence. This programme combines Windows, Linux, virtualisation, cloud and automation so you can design, run and secure any environment.",
      "system.hero.ctaPrimary": "Book your intake",
      "system.hero.ctaSecondary": "View programme",
      "system.hero.caption":
        "Work in enterprise labs featuring Windows, Linux, VMware, Hyper-V and cloud platforms.",
      "system.hero.metaTitle": "Start dates",
      "system.hero.metaDates": "14 October 2025 / 10 February 2026",
      "system.hero.metaNote":
        "Choose your intake path based on your experience. The intake determines which modules you start with.",
      "system.overview.label": "What you learn",
      "system.overview.title": "Full control over infrastructure",
      "system.overview.text1":
        "Gain expertise in managing servers, storage, networking and identity. Windows Server, Linux, Active Directory, PowerShell and Bash become second nature.",
      "system.overview.text2":
        "Automation and monitoring are central. Write scripts, use configuration management and work with Azure, VMware, Proxmox and Ansible.",
      "system.overview.listTitle": "During the programme",
      "system.overview.list1": "Hands-on labs on Windows, Linux, virtualisation and storage",
      "system.overview.list2": "Projects involving Microsoft 365, Azure AD, Intune and hybrid cloud",
      "system.overview.list3": "Focus on security, backup and business continuity",
      "system.overview.list4": "Internship project with one of our infrastructure partners",
      "system.modules.label": "Curriculum",
      "system.modules.title": "Modules & expertise areas",
      "system.modules.lead":
        "Each module blends theory with lab cases so you can manage production systems afterwards.",
      "system.modules.windowsTitle": "Windows & Microsoft 365",
      "system.modules.windowsBody":
        "Active Directory, Group Policy, Intune, Exchange Online and Teams. Automate with PowerShell and manage endpoints using modern management.",
      "system.modules.linuxTitle": "Linux & open source",
      "system.modules.linuxBody":
        "Linux server management, shell scripting, services, containerisation and monitoring with open-source tooling.",
      "system.modules.virtualizationTitle": "Virtualisation & cloud",
      "system.modules.virtualizationBody":
        "VMware, Hyper-V, Proxmox, Azure infrastructure, IaC and backup solutions for hybrid environments.",
      "system.modules.securityTitle": "Security & automation",
      "system.modules.securityBody":
        "Hardening, patch management, incident response, SIEM introduction and automation with Ansible and PowerShell DSC.",
      "system.journey.label": "Journey",
      "system.journey.title": "Your growth in four phases",
      "system.journey.step1Title": "Intake & fundamentals",
      "system.journey.step1Body":
        "Language and logic assessments, introductory project and refresh of core networking and OS administration.",
      "system.journey.step2Title": "Server & platform operations",
      "system.journey.step2Body":
        "Advanced configurations, automation and monitoring in labs with real-world scenarios.",
      "system.journey.step3Title": "Cloud & security",
      "system.journey.step3Body":
        "Hybrid architectures, identity, governance and security by design. Preparation for certifications such as Microsoft AZ-104.",
      "system.journey.step4Title": "Internship & career coaching",
      "system.journey.step4Body":
        "Eight-week internship, portfolio building, interview training and employer matching.",
      "system.cta.title": "Become the backbone of every IT infrastructure",
      "system.cta.body":
        "Book your intake and take the step toward roles such as system administrator, cloud engineer or platform specialist.",
      "system.cta.primary": "Book intake",
      "system.cta.secondary": "Ask a question",

      "security.hero.eyebrow": "Programme",
      "security.hero.title": "Cyber Security Engineer",
      "security.hero.lead":
        "Learn to detect, stop and prevent cyber attacks. Combine ethical hacking with security architecture, monitoring and incident response for networks, servers and cloud.",
      "security.hero.ctaPrimary": "Book your intake",
      "security.hero.ctaSecondary": "View programme",
      "security.hero.caption":
        "Work with SOC tooling, SIEM, forensics and red-team platforms guided by experts.",
      "security.hero.metaTitle": "Start date",
      "security.hero.metaDates": "3 March 2026",
      "security.hero.metaNote":
        "Intake includes a security mindset check, logic tests and a refresh of core networking.",
      "security.overview.label": "What you learn",
      "security.overview.title": "Defend every layer of the organisation",
      "security.overview.text1":
        "Analyse vulnerabilities, perform pentests and build defensive mechanisms. We blend blue team, red team and governance so you secure end-to-end.",
      "security.overview.text2":
        "Build security programmes that cover people, process and technology. Work with frameworks such as NIST, CIS and ISO 27001.",
      "security.overview.listTitle": "During the programme",
      "security.overview.list1": "Labs covering network, endpoint and cloud security",
      "security.overview.list2": "Threat hunting inside a simulated Security Operations Center",
      "security.overview.list3": "Incident response exercises with forensics and reporting",
      "security.overview.list4": "Internship at companies, public sector or SOC partners",
      "security.modules.label": "Curriculum",
      "security.modules.title": "Modules & labs",
      "security.modules.lead":
        "Each block mixes theory with lab scenarios. You work with up-to-date tools, frameworks and case files.",
      "security.modules.networkTitle": "Network & endpoint security",
      "security.modules.networkBody":
        "Firewalls, IDS/IPS, secure configuration, zero trust, endpoint hardening and patch management.",
      "security.modules.siemaTitle": "SOC & threat detection",
      "security.modules.siemaBody":
        "SIEM, log analytics, threat hunting, MITRE ATT&CK, automation with SOAR playbooks and reporting.",
      "security.modules.offensiveTitle": "Ethical hacking & forensics",
      "security.modules.offensiveBody":
        "Pentesting, exploit development, red teaming, forensic imaging and malware analysis.",
      "security.modules.governanceTitle": "Governance & cloud security",
      "security.modules.governanceBody":
        "NIST, CIS controls, ISO 27001, risk analysis, cloud security posture and compliance management.",
      "security.journey.label": "Journey",
      "security.journey.title": "From fundamentals to security specialist",
      "security.journey.step1Title": "Intake & fundamentals",
      "security.journey.step1Body":
        "Screening, refresh of networking and operating systems, introduction to the security mindset and tooling.",
      "security.journey.step2Title": "Blue team labs",
      "security.journey.step2Body":
        "Monitoring, detection, incident handling and reporting inside a simulated SOC.",
      "security.journey.step3Title": "Red team & forensics",
      "security.journey.step3Body":
        "Pentesting, exploitation, reverse engineering and forensic investigations using real case studies.",
      "security.journey.step4Title": "Internship & certification",
      "security.journey.step4Body":
        "Eight-week internship, coaching towards certifications such as CompTIA Security+, Cisco CCST or EC-Council, plus intensive job matching.",
      "security.cta.title": "Protect organisations from digital threats",
      "security.cta.body":
        "Book your intake and discover how you can make the difference as a cyber security engineer, SOC analyst or incident responder.",
      "security.cta.primary": "Book intake",
      "security.cta.secondary": "Ask a question",

