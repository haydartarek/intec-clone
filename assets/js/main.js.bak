      "home.hero.eyebrow": "Accredited VDAB programmes",
      "home.hero.title": "Discover our current range of accredited VDAB programmes",
      "home.hero.lead":
        "INTEC Brussels guides you towards a sustainable IT career with programmes that combine technical skills, language support and coaching. We build bridges between talent and employers who embrace diversity.",
      "home.hero.ctaPrimary": "View programmes",
      "home.hero.ctaSecondary": "Book an intake",
      "home.hero.caption":
        "Campus labs, blended learning and industry coaches help you master every step of the journey.",

      "home.courses.label": "Programmes",
      "home.courses.title": "Tracks that accelerate your career",
      "home.courses.lead":
        "Our accredited VDAB programmes focus on future-proof IT skills. You learn in small groups with digicoaches and language support available at every moment.",
      "home.courses.pc.title": "PC & Network Technician",
      "home.courses.pc.body":
        "Build expertise in hardware installations, server management and troubleshooting network incidents for SMEs and large organisations.",
      "home.courses.pc.date1": "Start dates: 7 October 2025",
      "home.courses.pc.date2": "Additional intake: 13 January 2026",
      "home.courses.pc.cta": "Programme details",
      "home.courses.python.title": "Network Administrator with Python",
      "home.courses.python.body":
        "Combine network architecture, automation and Python scripting to monitor and manage infrastructures with maximum efficiency.",
      "home.courses.python.date1": "Start date: 18 November 2025",
      "home.courses.python.cta": "Programme details",
      "home.courses.systems.title": "System Administrator",
      "home.courses.systems.body":
        "Learn to manage Windows and Linux servers, deploy virtualisation platforms and configure cloud resources securely.",
      "home.courses.systems.date1": "Start dates: 14 October 2025",
      "home.courses.systems.date2": "Language pathway intake: 10 February 2026",
      "home.courses.systems.cta": "Programme details",
      "home.courses.cyber.title": "Cyber Security Engineer",
      "home.courses.cyber.body":
