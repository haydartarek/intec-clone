      "register.label": "Enrol",
      "register.title": "Start your journey with an intake interview",
      "register.intro":
        "Every programme starts with an intake. Together we explore your motivation, availability, digital skills and language level so your learning path is tailored from day one.",
      "register.hero.chip1": "Fully funded VDAB programme",
      "register.hero.chip2": "Intake within three working days",
      "register.hero.chip3": "Coaching & language support",
      "register.hero.ctaPrimary": "Start pre-registration",
      "register.hero.ctaSecondary": "View steps",
