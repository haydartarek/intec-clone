      "form.required.default": "This field is required.",
      "form.required.name": "Please enter your name.",
      "form.required.email": "Please enter your email address.",
      "form.required.phone": "Please enter your phone number.",
      "form.required.course": "Please select a programme.",
      "form.required.gender": "Please choose your gender.",
      "form.required.national": "Please enter your national register number.",
      "form.required.address": "Please enter your street and house number.",
      "form.required.postcode": "Please enter your postcode.",
      "form.required.city": "Please enter your city or municipality.",
      "form.required.message": "Please type your message.",
      "form.required.username": "Username is required.",
      "form.required.password": "Password is required.",
      "form.error.email": "Please double-check your email address.",
    },
  };

  const localeMap = {
    nl: "nl-BE",
    en: "en-GB",
  };

  const counterState = {
    elements: [],
    observer: null,
  };

  let currentLanguage =
    localStorage.getItem("intec-language") || defaultLanguage;

  const registeredForms = [];

  const getTranslation = (lang, key) =>
    (translations[lang] && translations[lang][key]) ||
    (translations[defaultLanguage] && translations[defaultLanguage][key]) ||
    "";

  const translate = (key, fallback = "") =>
    getTranslation(currentLanguage, key) || fallback;

  window.__translate = (key, fallback = "") => translate(key, fallback);
  window.__getCurrentLanguage = () => currentLanguage;

  const formatCounterValue = (value, element) => {
    const locale =
      localeMap[currentLanguage] ||
      localeMap[defaultLanguage] ||
      "nl-BE";
    const decimals = Math.max(
      0,
      parseInt(element?.dataset.decimals || "0", 10)
    );
    const prefix = element?.dataset.prefix || "";
    const suffix = element?.dataset.suffix || "";
    const formatter = new Intl.NumberFormat(locale, {
      minimumFractionDigits: decimals,
      maximumFractionDigits: decimals,
    });
    return `${prefix}${formatter.format(value)}${suffix}`;
  };

  const updateCountersLocale = () => {
    if (!counterState.elements.length) {
      return;
    }
    counterState.elements.forEach((element) => {
      if (element.dataset.counterComplete === "true") {
        const target = parseFloat(element.dataset.target || "0");
        element.textContent = formatCounterValue(target, element);
      } else {
        element.textContent = formatCounterValue(0, element);
      }
    });
  };

  const animateCounter = (element) => {
    if (!element || element.dataset.counterStarted === "true") {
      return;
    }
    element.dataset.counterStarted = "true";

    const target = parseFloat(element.dataset.target || "0");
    if (Number.isNaN(target)) {
      element.dataset.counterComplete = "true";
      return;
    }

    const duration = Math.max(
      0,
      parseInt(element.dataset.duration || "2000", 10)
    );
    const decimals = Math.max(
      0,
      parseInt(element.dataset.decimals || "0", 10)
    );

    const start = performance.now();

    const step = (now) => {
      const progress =
        duration === 0 ? 1 : Math.min((now - start) / duration, 1);

      let currentValue;
      if (progress === 1) {
        currentValue = target;
      } else if (decimals > 0) {
        currentValue = parseFloat((target * progress).toFixed(decimals));
      } else {
        currentValue = Math.floor(target * progress);
      }

      element.textContent = formatCounterValue(currentValue, element);

      if (progress < 1) {
        requestAnimationFrame(step);
      } else {
        element.textContent = formatCounterValue(target, element);
        element.dataset.counterComplete = "true";
        if (counterState.observer) {
          counterState.observer.unobserve(element);
        }
      }
    };

    requestAnimationFrame(step);
  };

  const setupCounters = () => {
    const elements = Array.from(document.querySelectorAll("[data-counter]"));
    if (!elements.length) {
      return;
    }

    counterState.elements = elements;

    if (!counterState.observer) {
      counterState.observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              animateCounter(entry.target);
            }
          });
        },
        {
          threshold: 0.4,
          rootMargin: "0px 0px -15% 0px",
        }
      );
    }

    elements.forEach((element) => {
      if (element.dataset.counterBound !== "true") {
        counterState.observer.observe(element);
        element.dataset.counterBound = "true";
      }
      if (element.dataset.counterComplete !== "true") {
        element.dataset.counterStarted = "false";
      }
    });

    updateCountersLocale();
  };

  const applyTranslations = () => {
    document.querySelectorAll("[data-i18n]").forEach((node) => {
      const key = node.getAttribute("data-i18n");
      if (!key) return;

      const allowHtml = node.dataset.i18nAllowHtml === "true";
      const value = translate(key);
      if (!value) return;

      if (allowHtml) {
        node.innerHTML = value;
      } else {
        node.textContent = value;
      }
    });

    document.querySelectorAll("[data-i18n-placeholder]").forEach((node) => {
      const key = node.getAttribute("data-i18n-placeholder");
      if (!key) return;
      const value = translate(key);
      if (value) {
        node.setAttribute("placeholder", value);
      }
    });

    document.querySelectorAll("[data-i18n-content]").forEach((node) => {
      const key = node.getAttribute("data-i18n-content");
      if (!key) return;
      const value = translate(key);
      if (value) {
        node.setAttribute("content", value);
      }
    });

    document.querySelectorAll("[data-i18n-aria-label]").forEach((node) => {
      const key = node.getAttribute("data-i18n-aria-label");
      if (!key) return;
      const value = translate(key);
      if (value) {
        node.setAttribute("aria-label", value);
      }
    });

    registeredForms.forEach(({ refreshErrors }) => refreshErrors());
    updateCountersLocale();
  };

  const updateLanguageButtons = () => {
    document.querySelectorAll("[data-lang-select]").forEach((button) => {
      const { lang } = button.dataset;
      const isActive = lang === currentLanguage;
      button.classList.toggle("is-active", isActive);
      button.setAttribute("aria-pressed", String(isActive));
    });
  };

  const setLanguage = (lang) => {
    if (!translations[lang]) {
      lang = defaultLanguage;
    }
    currentLanguage = lang;
    localStorage.setItem("intec-language", currentLanguage);
    document.documentElement.setAttribute("data-language", currentLanguage);
    updateLanguageButtons();
    applyTranslations();
    window.dispatchEvent(
      new CustomEvent("intecLanguageChanged", {
        detail: { language: currentLanguage },
      })
    );
  };

  document
    .querySelectorAll("[data-lang-select]")
    .forEach((button) =>
      button.addEventListener("click", () => setLanguage(button.dataset.lang))
    );

  const toggles = document.querySelectorAll("[data-nav-toggle]");
  toggles.forEach((toggle) => {
    const targetSelector = toggle.getAttribute("data-nav-toggle");
    const target = document.querySelector(targetSelector);
    if (!target) return;

    toggle.addEventListener("click", () => {
      target.classList.toggle("is-open");
      const isOpen = target.classList.contains("is-open");
      toggle.setAttribute("aria-expanded", String(isOpen));
    });
  });

  const emailPattern =
    /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  const setupCustomValidation = (form, { requiredKeys = {}, validators = {} }) => {
    if (!form) return;
    form.setAttribute("novalidate", "");

    const fields = Array.from(
      form.querySelectorAll("input, select, textarea")
    );

    const ensureErrorNode = (field) => {
      const label = field.closest("label");
      if (!label) return null;
      let errorNode = label.querySelector(".form-error");
      if (!errorNode) {
        errorNode = document.createElement("span");
        errorNode.className = "form-error";
        label.append(errorNode);
      }
      return errorNode;
    };

    const showError = (field, message) => {
      const errorNode = ensureErrorNode(field);
      if (!errorNode) return;
      errorNode.textContent = message;
      field.setAttribute("aria-invalid", "true");
      const label = field.closest("label");
      if (label) {
        label.classList.add("has-error");
      }
    };

    const clearError = (field) => {
      const label = field.closest("label");
      if (!label) return;
      const errorNode = label.querySelector(".form-error");
      if (errorNode) {
        errorNode.textContent = "";
      }
      field.removeAttribute("aria-invalid");
      label.classList.remove("has-error");
    };

    const validateField = (field, force = false) => {
      const label = field.closest("label");
      if (!label) return true;

      const value =
        field.tagName === "SELECT" ? field.value : field.value.trim();

      const key = field.name || field.id;
      const isRequired = field.hasAttribute("required");
      let message = "";

      if (isRequired && !value) {
        const requiredKey = requiredKeys[key] || "form.required.default";
        message = translate(requiredKey, "Dit veld is verplicht.");
      } else if (validators[key]) {
        message = validators[key](value, field) || "";
      }

      if (message) {
        showError(field, message);
        return false;
      }

      if (force || label.classList.contains("has-error")) {
        clearError(field);
      }
      return true;
    };

    const markTouched = (field) => {
      field.dataset.touched = "true";
    };

    fields.forEach((field) => {
      const eventName = field.tagName === "SELECT" ? "change" : "input";
      field.addEventListener(eventName, () => {
        if (field.dataset.touched === "true") {
          validateField(field, true);
        }
      });
      field.addEventListener("blur", () => {
        markTouched(field);
        validateField(field, true);
      });
    });

    form.addEventListener("submit", (event) => {
      let isValid = true;
      fields.forEach((field) => {
        const fieldValid = validateField(field, true);
        if (!fieldValid) {
          isValid = false;
        }
      });
      if (!isValid) {
        event.preventDefault();
        const firstInvalid = fields.find((field) =>
          field.matches("[aria-invalid='true']")
        );
        if (firstInvalid) {
          firstInvalid.focus({ preventScroll: false });
        }
      }
    });

    registeredForms.push({
      refreshErrors: () => {
        fields.forEach((field) => {
          if (
            field.dataset.touched === "true" ||
            field.closest("label")?.classList.contains("has-error")
          ) {
            validateField(field, true);
          }
        });
      },
    });
  };

  setupCustomValidation(document.querySelector("#registration-form"), {
    requiredKeys: {
      "full-name": "form.required.name",
      gender: "form.required.gender",
      email: "form.required.email",
      phone: "form.required.phone",
      "national-number": "form.required.national",
      address: "form.required.address",
      postcode: "form.required.postcode",
      city: "form.required.city",
      course: "form.required.course",
    },
    validators: {
      email: (value) =>
        !value || emailPattern.test(value)
          ? ""
          : translate("form.error.email", "Controleer je e-mailadres."),
    },
  });

  setupCustomValidation(document.querySelector("#contact-form"), {
    requiredKeys: {
      name: "form.required.name",
      email: "form.required.email",
      message: "form.required.message",
    },
    validators: {
      email: (value) =>
        !value || emailPattern.test(value)
          ? ""
          : translate("form.error.email", "Controleer je e-mailadres."),
    },
  });

  setupCustomValidation(document.querySelector("#partner-login-form"), {
    requiredKeys: {
      username: "form.required.username",
      password: "form.required.password",
    },
  });

  setupCounters();

  const yearNode = document.getElementById("year");
  if (yearNode) {
    yearNode.textContent = new Date().getFullYear();
  }

  setLanguage(currentLanguage);
});








